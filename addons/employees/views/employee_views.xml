<odoo>
    <record id="view_employee_form_inherit_employees" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.employees</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Employee Details">
                    <group>
                        <field name="CURP"/>
                        <field name="RFC"/>
                        <field name="NSS"/>
                        <field name="Est"/>
                    </group>
                </page>
            </xpath>
            </field>
    </record>
</odoo>